# Пример генерации `./.env` (без секретных значений)
#
# После первого успешного `make env`:
# · IIKO_* подтягиваются из всех `../*/.env` и `../*/*/.env` соседних проектов
# · POSTGRES_* / DATABASE_URL — только из `.credentials.env` или уже существующего `./.env`,
#   либо из явного списка `IIKO_ENV_SOURCE`
# · `IIKO_RESTO_BASE_URL`, `IIKO_OLAP_SERVER_URL` всегда → hatimaki-co (bootstrap)
#
# Обязательно создайте `.credentials.env` (см. `.credentials.env.example`) перед `docker compose`.

# Postgres (локальный docker-compose; заполняется через .credentials.env)
POSTGRES_DB=
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_PORT=54337
DATABASE_URL=

# Scheduler intervals. In normal operation docker compose service `etl`
# runs continuously; manual commands are for debugging/recovery only.
DATALENS_REALTIME_INTERVAL_SECONDS=60
DATALENS_OLAP_TODAY_INTERVAL_SECONDS=600
DATALENS_BACKFILL_INTERVAL_SECONDS=1800
DATALENS_RECONCILE_INTERVAL_SECONDS=3600
DATALENS_RECONCILE_DAYS=7
DATALENS_BACKFILL_ENABLED=1

# Realtime Cloud delivery statuses. If an iiko account rejects some status,
# narrow this list in .credentials.env or .env.
IIKO_REALTIME_DELIVERY_STATUSES=Unconfirmed,WaitCooking,ReadyForCooking,CookingStarted,CookingCompleted,Waiting,OnWay,Delivered,Closed,Cancelled,closed
IIKO_SYNC_STOPLISTS=false

# iikoCloud (пример имён ключей после merge)
IIKO_CLOUD_API_BASE_URL=
IIKO_API_BASE_URL=
IIKO_API_LOGIN=
IIKO_API_KEY=

# Сервер OLAP и REST хост после bootstrap фиксируются скриптом:
# IIKO_RESTO_BASE_URL=https://hatimaki-co.iiko.it:443/resto
# IIKO_OLAP_SERVER_URL=https://hatimaki-co.iiko.it:443

IIKO_LOGIN=
IIKO_PASSWORD=
IIKO_PASSWORD_SHA1=

IIKO_OLAP_ENABLED=
IIKO_OLAP_LOGIN=
IIKO_OLAP_PASSWORD=
IIKO_OLAP_CHUNK_DAYS=
IIKO_OLAP_LOOKBACK_DAYS=
IIKO_OLAP_PHONE_FIELD=
IIKO_OLAP_DATE_FIELD=
IIKO_OLAP_DEPT_CODE_FIELD=
IIKO_OLAP_VERIFY_SSL=
IIKO_OLAP_MAX_WORKERS=
