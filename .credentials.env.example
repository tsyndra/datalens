# Пример секретов **только** для этого репозитория (Postgres/DataLens подключение).
# Скопируйте: `cp .credentials.env.example .credentials.env`
# затем выполните `make env && docker compose up -d`.

POSTGRES_DB=iiko_analytics
POSTGRES_USER=analytics
POSTGRES_PASSWORD=replace_me_secure
POSTGRES_PORT=54337

# Рекомендуемые URL для синх-хронизации (host с хост-машины, порт см. POSTGRES_PORT выше).
DATABASE_URL=postgresql://analytics:replace_me_secure@127.0.0.1:54337/iiko_analytics

# Опционально: роли для DataLens только на чтение (создайте в БД вручную позже по MVP-документу).
DATALENS_READER_PASSWORD=replace_me_datalens_reader_password
# DATALENS_READER_DATABASE_URL=postgresql://datalens_reader:replace_me_datalens_reader_password@127.0.0.1:54337/iiko_analytics
